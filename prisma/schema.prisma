generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  price       Float
  stock       Int
  category    String
  createdById Int?
  createdBy   AdminAccount? @relation("ProductsCreated", fields: [createdById], references: [id], onDelete: SetNull)
}

model AdminAccount {
  id                    Int            @id @default(autoincrement())
  username              String         @unique
  passwordHash          String
  passwordSalt          String
  role                  String         @default("admin")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  clientsCreated        Client[]       @relation("ClientsCreated")
  productsCreated       Product[]      @relation("ProductsCreated")
  salesRecorded         SalesRecord[]  @relation("SalesRecorded")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  notificationsCreated  Notification[] @relation("NotificationsCreated")
}

model Client {
  dni           Int           @id
  nameComplete  String
  joinDate      DateTime
  fee           Float
  mode          String
  paymentMethod String
  turn          String
  debt          Float         @default(0)
  status        String        @default("active")
  createdById   Int?
  createdBy     AdminAccount? @relation("ClientsCreated", fields: [createdById], references: [id], onDelete: SetNull)
  appointments  Appointment[]
  boletas       Boleta[]
  sales         SalesRecord[]
}

model SalesRecord {
  id        Int      @id @default(autoincrement())
  saleDate  DateTime
  product   String
  amount    Float
  clientDni Int
  soldById  Int?
  client    Client   @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
  soldBy    AdminAccount? @relation("SalesRecorded", fields: [soldById], references: [id], onDelete: SetNull)
}

model Notification {
  id          Int           @id @default(autoincrement())
  recipientId Int
  actorId     Int?
  type        String
  title       String
  message     String
  entityType  String?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  recipient   AdminAccount  @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       AdminAccount? @relation("NotificationsCreated", fields: [actorId], references: [id], onDelete: SetNull)
}

model Boleta {
  id          Int      @id @default(autoincrement())
  receiptDate DateTime
  product     String
  amount      Float
  tax         Float
  total       Float
  clientDni   Int
  client      Client   @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
}

model Factura {
  id           Int      @id @default(autoincrement())
  invoiceDate  DateTime
  supplierName String
  ruc          String
  product      String
  amount       Float
  tax          Float
  total        Float
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  scheduled DateTime
  clientDni Int
  client    Client   @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
}
