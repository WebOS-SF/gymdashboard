generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          Int           @id @default(autoincrement())
  name        String
  price       Float
  stock       Int
  category    String
  createdById Int?
  createdBy   AdminAccount? @relation("ProductsCreated", fields: [createdById], references: [id])
}

model AdminAccount {
  id                    Int            @id @default(autoincrement())
  username              String         @unique
  passwordHash          String
  passwordSalt          String
  role                  String         @default("admin")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  clientsCreated        Client[]       @relation("ClientsCreated")
  clientPlansCreated    ClientPlan[]   @relation("ClientPlansCreated")
  notificationsCreated  Notification[] @relation("NotificationsCreated")
  notificationsReceived Notification[] @relation("NotificationsReceived")
  productsCreated       Product[]      @relation("ProductsCreated")
  salesRecorded         SalesRecord[]  @relation("SalesRecorded")
}

model Client {
  dni           Int           @id
  nameComplete  String
  joinDate      DateTime
  fee           Float
  mode          String
  paymentMethod String
  turn          String
  debt          Float         @default(0)
  status        String        @default("active")
  phone         String?
  createdById   Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  appointments  Appointment[]
  attendances   Attendance[]
  boletas       Boleta[]
  createdBy     AdminAccount? @relation("ClientsCreated", fields: [createdById], references: [id])
  plans         ClientPlan[]
  sales         SalesRecord[]
}

model ClientPlan {
  id              Int           @id @default(autoincrement())
  clientDni       Int
  name            String
  startDate       DateTime
  endDate         DateTime
  durationValue   Int
  durationUnit    String
  attendanceDays  String[]
  attendanceLabel String
  pricingMode     String
  sessionCount    Int
  totalPrice      Float
  amountPaid      Float
  debt            Float         @default(0)
  paymentState    String
  paymentSeverity String        @default("none")
  paymentMethod   String
  turn            String
  status          String        @default("active")
  planTier        String
  createdById     Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
  createdBy       AdminAccount? @relation("ClientPlansCreated", fields: [createdById], references: [id])

  @@index([clientDni, startDate])
  @@index([status, paymentSeverity, endDate])
}

model SalesRecord {
  id            Int           @id @default(autoincrement())
  saleDate      DateTime
  product       String
  amount        Float
  clientDni     Int
  isPaid        Boolean       @default(true)
  soldById      Int?
  paymentMethod String        @default("Efectivo")
  client        Client        @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
  soldBy        AdminAccount? @relation("SalesRecorded", fields: [soldById], references: [id])
}

model Notification {
  id          Int           @id @default(autoincrement())
  recipientId Int
  actorId     Int?
  type        String
  title       String
  message     String
  entityType  String?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime      @default(now())
  actor       AdminAccount? @relation("NotificationsCreated", fields: [actorId], references: [id])
  recipient   AdminAccount  @relation("NotificationsReceived", fields: [recipientId], references: [id], onDelete: Cascade)
}

model Boleta {
  id          Int      @id @default(autoincrement())
  receiptDate DateTime
  product     String
  amount      Float
  tax         Float
  total       Float
  clientDni   Int
  client      Client   @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
}

model Factura {
  id           Int      @id @default(autoincrement())
  invoiceDate  DateTime
  supplierName String
  ruc          String
  product      String
  amount       Float
  tax          Float
  total        Float
}

model Attendance {
  id        String           @id @default(cuid())
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  clientDni Int
  client    Client           @relation(fields: [clientDni], references: [dni], onDelete: Cascade)

  @@unique([clientDni, date])
}

model Appointment {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String
  scheduled DateTime
  clientDni Int
  client    Client   @relation(fields: [clientDni], references: [dni], onDelete: Cascade)
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}
